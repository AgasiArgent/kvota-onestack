# ===== OPTION A: Local PostgreSQL (for testing without Supabase) =====
# Start with: docker compose -f docker-compose.dev.yml up -d
# Then run:   python scripts/setup_local_db.py
#
# NOTE: Local PG does NOT have Supabase Auth — only the data layer works.
# Use this for migration testing, seed data, and service-level unit tests.
DATABASE_URL=postgresql://kvota:devpassword@localhost:5434/kvota_dev

# Supabase vars are required by the app but won't connect to anything real.
# The app will fail on auth-related operations with local PG.
SUPABASE_URL=http://localhost:5434
SUPABASE_KEY=dev-key-not-used
SUPABASE_ANON_KEY=dev-anon-key-not-used
SUPABASE_SERVICE_ROLE_KEY=dev-service-role-key-not-used

# ===== OPTION B: SSH Tunnel to VPS Supabase (for local dev with real data) =====
# Start tunnel: ~/.claude/scripts/db-tunnel.sh start
# This opens localhost:54320 → VPS Supabase PostgreSQL
# Copy SUPABASE_URL, SUPABASE_KEY, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY from .env
# DATABASE_URL=postgresql://postgres:1MQs7TdFmel4vxvDiPG79AxG73LAKSQa@localhost:54320/postgres

# === App Settings ===
APP_SECRET=dev-secret-change-me
DEBUG=true
PORT=5001

# === Telegram Bot (optional for local dev) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=
ADMIN_TELEGRAM_CHAT_ID=

# === DaData (optional for local dev) ===
DADATA_API_KEY=

# === HERE Maps (optional for local dev) ===
HERE_API_KEY=

# === Sentry (disabled for local dev) ===
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# === ClickUp (optional for local dev) ===
CLICKUP_API_KEY=
CLICKUP_BUG_LIST_ID=

# === Cron Security ===
CRON_SECRET=your-cron-secret-here

# === App URL ===
APP_BASE_URL=http://localhost:5001
