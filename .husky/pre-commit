#!/usr/bin/env sh
# Customer-Journey-Map manifest regeneration — pre-commit hook.
#
# Source-of-truth copy of the hook; husky `prepare` step copies this file into
# `.husky/pre-commit` on `npm install` (see `frontend/package.json` scripts).
#
# Intent: whenever a developer stages a file that feeds the journey manifest
# (App Router pages, spec docs, access-control.md), regenerate
# `frontend/public/journey-manifest.json` and restage it so the committed
# artefact never drifts from source.
#
# Req 1.2 in `.kiro/specs/customer-journey-map/requirements.md`.

staged="$(git diff --cached --name-only --diff-filter=ACMR)"

needs_rebuild=0
case "${staged}" in
  *frontend/src/app/*) needs_rebuild=1 ;;
esac
if [ "${needs_rebuild}" -eq 0 ]; then
  case "${staged}" in
    *.kiro/specs/*) needs_rebuild=1 ;;
  esac
fi
if [ "${needs_rebuild}" -eq 0 ]; then
  case "${staged}" in
    *.kiro/steering/access-control.md*) needs_rebuild=1 ;;
  esac
fi

if [ "${needs_rebuild}" -eq 1 ]; then
  echo "[husky] Rebuilding frontend/public/journey-manifest.json…"
  (cd frontend && npm run --silent journey:build) || {
    echo "[husky] journey:build failed — aborting commit"
    exit 1
  }
  git add frontend/public/journey-manifest.json
fi
